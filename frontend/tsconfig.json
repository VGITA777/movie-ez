{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@spartan-ng/helm/button": ["./libs/ui/button/src/index.ts"],
      "@spartan-ng/helm/button-group": ["./libs/ui/button-group/src/index.ts"],
      "@spartan-ng/helm/icon": ["./libs/ui/icon/src/index.ts"],
      "@spartan-ng/helm/input": ["./libs/ui/input/src/index.ts"],
      "@spartan-ng/helm/input-group": ["./libs/ui/input-group/src/index.ts"],
      "@spartan-ng/helm/label": ["./libs/ui/label/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./libs/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/toggle": ["./libs/ui/toggle/src/index.ts"],
      "@spartan-ng/helm/toggle-group": ["./libs/ui/toggle-group/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["./libs/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/utils": ["./libs/ui/utils/src/index.ts"],
      "@spartan-ng/helm/textarea": ["./libs/ui/textarea/src/index.ts"],
      "@spartan-ng/helm/carousel": ["./libs/ui/carousel/src/index.ts"],
      "@app/*": ["./src/app/*"],
      "@home/*": ["./src/app/home/*"],
      "@watch/*": ["./src/app/watch/*"],
      "@search/*": ["./src/app/search/*"],
      "@notfound/*": ["./src/app/not-found/*"],
      "@shared/*": ["./src/app/shared/*"],
      "@models/*": ["./src/app/shared/model/*"],
      "@environments/*": ["./src/environments/*"],
      "@spartan-ng/helm/card": ["./libs/ui/card/src/index.ts"],
      "@spartan-ng/helm/sonner": ["./libs/ui/sonner/src/index.ts"],
      "@spartan-ng/helm/dialog": ["./libs/ui/dialog/src/index.ts"],
      "@spartan-ng/helm/select": ["./libs/ui/select/src/index.ts"],
      "@spartan-ng/helm/item": ["./libs/ui/item/src/index.ts"],
      "@spartan-ng/helm/separator": ["./libs/ui/separator/src/index.ts"],
      "@spartan-ng/helm/scroll-area": ["./libs/ui/scroll-area/src/index.ts"],
      "@spartan-ng/helm/avatar": ["./libs/ui/avatar/src/index.ts"],
      "@spartan-ng/helm/radio-group": ["./libs/ui/radio-group/src/index.ts"],
      "@spartan-ng/helm/empty": ["./libs/ui/empty/src/index.ts"],
      "@spartan-ng/helm/badge": ["./libs/ui/badge/src/index.ts"],
      "@spartan-ng/helm/navigation-menu": ["./libs/ui/navigation-menu/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
